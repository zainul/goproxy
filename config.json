{
  "listen_addr": ":8080",
  "enable_singleflight": true,
  "redis": {
    "addr": "localhost:6379",
    "password": "",
    "db": 0
  },
  "backends": [
    {
      "url": "http://httpbin.org",
      "circuit_breaker": {
        "failure_threshold": 5,
        "success_threshold": 3,
        "timeout": "10s",
        "counter_type": "ringbuffer",
        "window_size": 10
      },
      "rate_limiter": {
        "type": "sliding_window",
        "limit": 100,
        "window": 60,
        "dynamic": true,
        "damage_level": 0.5,
        "catastrophic_level": 0.8,
        "healthy_increment": 0.01,
        "unhealthy_decrement": 0.01,
        "priority": 1
      },
      "endpoints": [
        {
          "path": "/api/high",
          "rate_limiter": {
            "type": "token_bucket",
            "limit": 50,
            "window": 10,
            "dynamic": true,
            "damage_level": 0.3,
            "catastrophic_level": 0.7,
            "healthy_increment": 0.02,
            "unhealthy_decrement": 0.02,
            "priority": 3
          }
        }
      ]
    }
  ]
}